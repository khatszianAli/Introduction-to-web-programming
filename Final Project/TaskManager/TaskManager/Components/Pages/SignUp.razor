@page "/register"
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Nav

@attribute [RequireAntiforgeryToken(required: false)]

<div style="text-align: center; margin-top: 40px;">
    <h2>Регистрация</h2>
    <p style="color: #64748b;">Создайте аккаунт, чтобы управлять группами</p>
</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger" style="color: red; text-align: center; margin-bottom: 15px;">
        @ErrorMessage
    </div>
}

<form class="task-form" method="post" action="/auth/register" @formname="RegistrationForm">
    <div class="form-group">
        <label>Имя пользователя</label>
        <input name="username" class="form-control" placeholder="ivan_ivanov" required />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input name="email" type="email" class="form-control" placeholder="example@mail.com" required />
    </div>

    <div class="form-group">
        <label>Пароль</label>
        <input name="password" type="password" class="form-control" placeholder="********" required />
    </div>

    <button type="submit" class="btn btn-primary" style="margin-top: 10px;">Создать аккаунт</button>
</form>

@code {
    private string? ErrorMessage;
    
    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        
        if (query.TryGetValue("error", out var errorCode) && errorCode == "exists")
        {
            ErrorMessage = "Пользователь с таким именем или email уже существует!";
        }
    }
}


